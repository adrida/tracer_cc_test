<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>tracerCC · Claude Code Wrapped</title>
<style>
  :root {
    --bg-0: #050507;
    --bg-1: #0b0f10;
    --fg:   #f4f7f5;
    --fg-dim: #9aa6a0;
    --green: #1dd66b;
    --green-dim: #178a47;
    --red:   #ff5b5b;
    --orange:#ffb547;
    --purple:#b18cff;
    --card:  rgba(255,255,255,0.04);
    --card-border: rgba(255,255,255,0.08);
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; background: var(--bg-0); color: var(--fg);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Inter, system-ui, sans-serif;
    font-feature-settings: "ss01","cv11"; -webkit-font-smoothing: antialiased; }
  a { color: var(--green); text-decoration: none; }
  .mono { font-family: ui-monospace, SFMono-Regular, "JetBrains Mono", Menlo, monospace; }
  .num  { font-variant-numeric: tabular-nums; font-feature-settings: "tnum"; }

  section { padding: 88px 32px; max-width: 1100px; margin: 0 auto; }
  section + section { border-top: 1px solid var(--card-border); }

  /* HERO */
  .hero {
    min-height: 100vh; display: flex; flex-direction: column; justify-content: center;
    background:
      radial-gradient(ellipse at 20% 0%, #0d3a22 0%, transparent 55%),
      radial-gradient(ellipse at 80% 100%, #251448 0%, transparent 55%),
      var(--bg-0);
    padding: 96px 32px;
  }
  .hero .label { text-transform: uppercase; letter-spacing: 0.18em;
    font-size: 13px; color: var(--green); margin-bottom: 24px; font-weight: 600; }
  .hero h1 { font-size: clamp(48px, 7vw, 96px); line-height: 1.02;
    font-weight: 800; letter-spacing: -0.03em; margin: 0 0 32px; }
  .hero h1 em { font-style: normal; color: var(--green); }
  .hero .sub { font-size: clamp(18px, 1.6vw, 22px); color: var(--fg-dim);
    max-width: 620px; line-height: 1.45; }
  .hero .meta { margin-top: 56px; color: var(--fg-dim); font-size: 14px; }
  .hero .meta b { color: var(--fg); font-weight: 600; }

  /* big stat */
  .bignum { font-size: clamp(80px, 14vw, 200px); font-weight: 800; letter-spacing: -0.04em;
    line-height: 0.95; margin: 0 0 24px; color: var(--green); }
  .bignum .ccy { font-size: 0.45em; vertical-align: 0.18em; color: var(--fg-dim);
    font-weight: 600; margin-right: 8px; }
  .bigsub { font-size: clamp(18px, 1.5vw, 22px); color: var(--fg-dim); max-width: 720px;
    line-height: 1.5; }
  .bigsub b { color: var(--fg); }

  /* chips / kpi grid */
  .kpis { display: grid; gap: 16px; margin-top: 48px;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); }
  .kpi { background: var(--card); border: 1px solid var(--card-border);
    border-radius: 16px; padding: 24px; }
  .kpi .k { font-size: 12px; color: var(--fg-dim); text-transform: uppercase;
    letter-spacing: 0.12em; font-weight: 600; }
  .kpi .v { font-size: 32px; font-weight: 700; margin-top: 8px;
    font-variant-numeric: tabular-nums; letter-spacing: -0.02em; }
  .kpi .d { font-size: 13px; color: var(--fg-dim); margin-top: 4px; }

  /* section heading */
  h2 { font-size: clamp(28px, 3vw, 44px); font-weight: 800; letter-spacing: -0.02em;
    margin: 0 0 12px; }
  h2 .accent { color: var(--green); }
  .lede { font-size: 17px; color: var(--fg-dim); max-width: 720px; line-height: 1.55;
    margin: 0 0 40px; }

  /* cluster cards */
  .clusters { display: grid; gap: 18px;
    grid-template-columns: repeat(auto-fill, minmax(420px, 1fr)); }
  .cl { background: var(--card); border: 1px solid var(--card-border);
    border-radius: 18px; padding: 28px; transition: transform 0.15s; }
  .cl:hover { transform: translateY(-2px); border-color: rgba(29,214,107,0.35); }
  .cl .label { font-size: 12px; color: var(--green); text-transform: uppercase;
    letter-spacing: 0.14em; font-weight: 700; }
  .cl .name { font-size: 22px; font-weight: 700; margin: 8px 0 16px; letter-spacing: -0.01em; }
  .cl .row { display: flex; justify-content: space-between; align-items: baseline;
    margin: 8px 0; }
  .cl .row .l { color: var(--fg-dim); font-size: 13px; }
  .cl .row .v { font-weight: 700; font-variant-numeric: tabular-nums; }
  .cl .v.actual { color: var(--red); }
  .cl .v.save   { color: var(--green); }
  .cl .bar { height: 8px; border-radius: 4px; background: rgba(255,255,255,0.06);
    margin: 14px 0 8px; overflow: hidden; position: relative; }
  .cl .bar .fill-actual { position: absolute; inset: 0; background: var(--red); opacity: 0.35; }
  .cl .bar .fill-save   { position: absolute; left: 0; top: 0; bottom: 0;
    background: var(--green); }
  .cl pre.medoid { background: rgba(0,0,0,0.4); border: 1px solid var(--card-border);
    border-radius: 10px; padding: 12px 14px; margin: 16px 0 0; font-size: 12.5px;
    line-height: 1.45; color: var(--fg); overflow-x: auto; max-height: 92px;
    white-space: pre-wrap; word-break: break-word; }
  .cl .ex { font-size: 12px; color: var(--fg-dim); margin-top: 12px; }
  .cl .ex span { display: block; padding: 4px 0; border-top: 1px dashed rgba(255,255,255,0.06);
    font-family: ui-monospace, monospace; word-break: break-word; }

  /* stat cards (fun stats) */
  .stats { display: grid; gap: 18px;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); }
  .stat { background: var(--card); border: 1px solid var(--card-border);
    border-radius: 16px; padding: 24px; }
  .stat .t { font-size: 12px; color: var(--purple); text-transform: uppercase;
    letter-spacing: 0.14em; font-weight: 700; }
  .stat .v { font-size: 28px; font-weight: 700; margin: 12px 0 6px;
    font-variant-numeric: tabular-nums; letter-spacing: -0.01em; }
  .stat .d { font-size: 14px; color: var(--fg-dim); line-height: 1.5; }

  /* sessions table */
  .sess { width: 100%; border-collapse: collapse; }
  .sess th { text-align: left; font-size: 12px; text-transform: uppercase;
    letter-spacing: 0.12em; color: var(--fg-dim); padding: 12px 16px; font-weight: 600;
    border-bottom: 1px solid var(--card-border); }
  .sess td { padding: 16px; border-bottom: 1px solid var(--card-border);
    font-size: 14px; vertical-align: top; }
  .sess td.spend { text-align: right; font-weight: 700; font-variant-numeric: tabular-nums;
    color: var(--orange); }
  .sess td .cwd { color: var(--fg-dim); font-size: 12px; font-family: ui-monospace, monospace; }

  /* trust */
  .trust { background:
      radial-gradient(ellipse at 100% 0%, #2c1130 0%, transparent 50%),
      var(--bg-1);
    border: 1px solid var(--card-border); border-radius: 22px; padding: 40px; }
  .trust h2 { color: var(--purple); }
  .trust .gauge { height: 22px; border-radius: 11px; background: rgba(255,255,255,0.06);
    margin: 24px 0 12px; overflow: hidden; display: flex; }
  .trust .gauge .seg-recommend { background: var(--green); }
  .trust .gauge .seg-excluded  { background: var(--purple); }
  .trust .legend { display: flex; gap: 24px; font-size: 13px; color: var(--fg-dim); }
  .trust .legend span { display: inline-flex; align-items: center; gap: 8px; }
  .trust .legend i { width: 12px; height: 12px; border-radius: 3px; display: inline-block; }

  /* method badge */
  .method { background: var(--card); border: 1px solid var(--card-border);
    border-radius: 18px; padding: 28px; }
  .method ol { margin: 16px 0 0; padding-left: 22px; line-height: 1.7; color: var(--fg-dim); }
  .method ol li b { color: var(--fg); }

  /* footer */
  footer { padding: 56px 32px 80px; text-align: center; color: var(--fg-dim);
    font-size: 13px; }
  footer a { font-weight: 600; }
</style>
</head>
<body>

{% set hero_save = (r.saving_cheapest_sibling_usd or 0) if (r.saving_cheapest_sibling_usd or 0) > 0 else r.saving_haiku_usd %}
{% set hero_premium = (r.premium_spend_usd or 0) if (r.premium_spend_usd or 0) > 0 else r.opus_spend_usd %}
{% set hero_pct = (r.saving_cheapest_sibling_pct_of_premium or 0) if (r.saving_cheapest_sibling_pct_of_premium or 0) > 0 else r.saving_haiku_pct_of_opus %}
{% set rp = r.routing_policy %}
{% set rules = rp.rules if rp else [] %}
{% set n_rules = rules|length %}
{% set window_save_total = 0 %}
{% if rules %}
  {% for rl in rules %}{% set window_save_total = window_save_total + rl.estimated_window_savings_usd %}{% endfor %}
{% endif %}
{% set span = r.span_days if r.span_days else 1 %}
{% set projected_monthly_save = (hero_save * 30 / span) if span else 0 %}
{% set n_high = 0 %}{% set n_med = 0 %}{% set n_low = 0 %}
{% if rules %}
  {% for rl in rules %}
    {% if rl.confidence == "high" %}{% set n_high = n_high + 1 %}
    {% elif rl.confidence == "medium" %}{% set n_med = n_med + 1 %}
    {% else %}{% set n_low = n_low + 1 %}{% endif %}
  {% endfor %}
{% endif %}

<!-- HERO: policy-led, not diagnostic-led -->
<section class="hero">
  <div class="label">tracerCC · fitted routing policy</div>
  {% if n_rules > 0 %}
  <h1>Deploy <em>{{ n_rules }}</em> routing rules.<br>Save ~<em>${{ projected_monthly_save|money }}</em>/mo.</h1>
  <p class="sub">
    Fitted on <b>{{ r.n_sessions|number }} of your own sessions</b> ({{ r.n_messages|number }} messages, {{ r.span_days }} days).
    Every rule maps a tool-call pattern your agent repeats to a cheaper sibling in the same model family.
    Per-rule evidence below; strict-gate by default.
  </p>
  {% else %}
  <h1>No routable patterns found.</h1>
  <p class="sub">
    From {{ r.n_sessions }} sessions over {{ r.span_days }} days we couldn't find dense clusters of
    mechanical work above the confidence bar. Either the corpus is too small or the workload
    is genuinely novel per turn. Run again after more traffic.
  </p>
  {% endif %}
  <div class="meta">
    <b>${{ hero_premium|money }}</b> priced spend · <b>${{ hero_save|money(2) }}</b> saveable in window ({{ hero_pct|money(1) }}%) ·
    {{ r.earliest[:10] }} → {{ r.latest[:10] }}
  </div>
</section>

{% if n_rules > 0 %}
<!-- THE POLICY: the actionable output -->
<section>
  <h2>The <span class="accent">policy</span></h2>
  <p class="lede">
    One row per rule. <b>Confidence</b> comes from cluster size + embedding density —
    start with <code>high</code>-only in production, loosen as the refit flywheel earns trust.
  </p>
  <div class="kpis" style="margin-bottom:40px;">
    <div class="kpi"><div class="k">Rules fitted</div><div class="v num">{{ n_rules }}</div><div class="d">from {{ r.n_mechanical_turns|number }} mechanical turns</div></div>
    <div class="kpi"><div class="k">High confidence</div><div class="v num" style="color:var(--green)">{{ n_high }}</div><div class="d">safe for day-one rollout</div></div>
    <div class="kpi"><div class="k">Medium</div><div class="v num" style="color:var(--orange)">{{ n_med }}</div><div class="d">enable after telemetry</div></div>
    <div class="kpi"><div class="k">Projected /mo</div><div class="v num" style="color:var(--green)">${{ window_save_total|money }}</div><div class="d">30d extrapolation, all rules</div></div>
  </div>
  <div style="overflow-x:auto;background:var(--card);border:1px solid var(--card-border);border-radius:16px;">
  <table style="width:100%;border-collapse:collapse;font-size:14px;">
    <thead>
      <tr style="color:var(--fg-dim);text-transform:uppercase;letter-spacing:0.08em;font-size:11px;">
        <th style="text-align:left;padding:14px 18px;">rule</th>
        <th style="text-align:left;padding:14px 8px;">pattern</th>
        <th style="text-align:center;padding:14px 8px;">conf.</th>
        <th style="text-align:right;padding:14px 8px;">n turns</th>
        <th style="text-align:left;padding:14px 8px;">route</th>
        <th style="text-align:right;padding:14px 8px;">$/call</th>
        <th style="text-align:right;padding:14px 18px;">$/30d</th>
      </tr>
    </thead>
    <tbody>
      {% for rl in rules %}
      <tr style="border-top:1px solid var(--card-border);">
        <td class="mono" style="padding:14px 18px;color:var(--fg-dim);">{{ rl.rule_id }}</td>
        <td style="padding:14px 8px;max-width:360px;">
          <div style="font-weight:600;">{{ rl.label }}</div>
          <div class="mono" style="color:var(--fg-dim);font-size:12px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{{ rl.medoid_example }}</div>
        </td>
        <td style="text-align:center;padding:14px 8px;">
          {% if rl.confidence == "high" %}<span style="color:var(--green);font-weight:700;">● high</span>{% elif rl.confidence == "medium" %}<span style="color:var(--orange);font-weight:700;">● med</span>{% else %}<span style="color:var(--fg-dim);">○ low</span>{% endif %}
        </td>
        <td style="text-align:right;padding:14px 8px;font-variant-numeric:tabular-nums;">{{ rl.n_training_turns }}</td>
        <td class="mono" style="padding:14px 8px;font-size:12px;">
          <div>{{ rl.source_model }}</div>
          <div style="color:var(--green);">→ {{ rl.target_model }}</div>
        </td>
        <td style="text-align:right;padding:14px 8px;font-variant-numeric:tabular-nums;">${{ rl.estimated_savings_per_call_usd|money(4) }}</td>
        <td style="text-align:right;padding:14px 18px;font-variant-numeric:tabular-nums;font-weight:600;color:var(--green);">${{ rl.estimated_window_savings_usd|money }}</td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
  </div>
</section>

<!-- HOW TO DEPLOY -->
<section>
  <h2>Deploy in <span class="accent">8 lines</span></h2>
  <p class="lede">
    Drop the runtime into whatever function wraps <code>openai.chat.completions.create</code>
    in your agent gateway. The router rewrites the <code>model</code> parameter when the
    session signature matches a rule; otherwise pass-through.
  </p>
  <pre style="background:var(--bg-1);padding:24px;border-radius:12px;overflow-x:auto;font-size:13px;line-height:1.55;border:1px solid var(--card-border);"><code class="mono">from tracercc.runtime import Router
import openai

router = Router.from_file("./tracer_policy.json", min_confidence="high")

def chat(messages, tools, default_model="{{ rp.default_model if rp else 'gpt-5-2' }}"):
    model, rule_id = router.route(messages=messages, tools=tools)
    result = openai.chat.completions.create(
        model=model or default_model, messages=messages, tools=tools,
    )
    router.record(rule_id, result)   # optional — feeds the refit flywheel
    return result</code></pre>
  <p class="lede" style="margin-top:32px;">
    <b>Recommended rollout:</b> start at <code>min_confidence="high"</code>
    ({{ n_high }} rule{{ 's' if n_high != 1 else '' }}, lowest risk, ~${{ ((window_save_total * n_high / (n_rules or 1)) if n_high else 0)|money }}/mo).
    After a week of telemetry (via <code>router.record()</code>), loosen to
    <code>"medium"</code> to unlock the rest. Re-run <code>tracercc</code> on the new
    traces anytime — the refit drops rules whose <code>ok=False</code> rate was high.
  </p>
</section>

{% if r.clustermap %}
<!-- INTERACTIVE CLUSTER MAP (D3, no Plotly) -->
<section>
  <h2>Your workloads, <span class="accent">clustered</span></h2>
  <p class="lede">
    Every dot is one mechanical turn from your traces, projected to 2D via TSNE
    on the BGE-M3 embedding of its tool-call payload. Turns that cluster together
    emit near-identical tool calls — that's the structural evidence behind each rule.
    <b>Hover a dot</b> to see the exact call. <b>Click a cluster label</b> to filter.
  </p>
  <div id="clustermap-root" style="position:relative;background:var(--bg-1);border:1px solid var(--card-border);border-radius:16px;padding:0;margin-top:24px;overflow:hidden;">
    <div id="clustermap-legend" style="position:absolute;top:14px;left:18px;z-index:2;font-size:11px;color:var(--fg-dim);max-width:240px;line-height:1.45;pointer-events:none;">
      <div style="color:var(--fg);font-weight:600;font-size:12px;margin-bottom:4px;">{{ r.n_mechanical_turns|number }} turns · {{ r.n_clusters }} clusters · {{ r.n_noise }} noise</div>
      each colour = one cluster · dot radius ∝ $ cost · labels show the top 12 by spend
    </div>
    <div id="clustermap-filter" style="position:absolute;top:14px;right:18px;z-index:2;font-size:12px;color:var(--green);cursor:pointer;display:none;">
      ✕ clear filter
    </div>
    <svg id="clustermap-svg" viewBox="-120 -80 240 160" preserveAspectRatio="xMidYMid meet"
         style="width:100%;height:640px;display:block;"></svg>
    <div id="clustermap-tooltip" style="position:absolute;pointer-events:none;background:var(--bg-0);border:1px solid var(--card-border);border-radius:8px;padding:10px 12px;font-size:12px;line-height:1.5;max-width:380px;opacity:0;transition:opacity .08s;z-index:3;box-shadow:0 8px 24px rgba(0,0,0,0.4);"></div>
  </div>
  <p class="lede" style="margin-top:24px;font-size:14px;">
    <b>Reading the map</b> — tight, tightly-coloured blobs are the rules the policy is confident in (many
    similar calls close together in semantic space). Wide, sparse regions are noise the structural gate deliberately
    excludes: not enough repetition to guarantee quality if we re-routed them. That's what "tracer discipline" means
    in practice — only claim savings where the evidence is dense.
  </p>
</section>

<script>
(function() {
  const POINTS = [
    {% for p in r.clustermap %}
    {x:{{ p.x }},y:{{ p.y }},cluster_id:{{ p.cluster_id }},tool_name:{{ p.tool_name | tojson }},cost_usd:{{ p.cost_usd }},text:{{ p.text | tojson }}},
    {% endfor %}
  ];
  const LABELS = [
    {% for l in r.cluster_labels %}
    {cluster_id:{{ l.cluster_id }},x:{{ l.x }},y:{{ l.y }},label:{{ l.label | tojson }},dominant_tool:{{ l.dominant_tool | tojson }},n_turns:{{ l.n_turns }},confidence:{{ l.confidence | tojson }}},
    {% endfor %}
  ];
  const svg = document.getElementById('clustermap-svg');
  const tip = document.getElementById('clustermap-tooltip');
  const root = document.getElementById('clustermap-root');
  const filter = document.getElementById('clustermap-filter');
  if (!POINTS.length) return;

  // Nice deterministic palette — cluster id → colour
  const PALETTE = [
    '#1dd66b', '#ffb547', '#b18cff', '#ff5b5b', '#5ec4ff',
    '#f97ae0', '#ffd83d', '#4dd4c1', '#ff8c42', '#8cf4a1',
    '#c890ff', '#ff6b9d', '#7be0d8', '#ffb3ba', '#84b1ff',
    '#bae67e', '#fff1a8', '#e9a3ff', '#ffa07a', '#9fd3c7',
    '#ffcc70', '#b5e5cf', '#f1bbd9', '#a8d8ea', '#d4a5a5',
    '#fedfe1',
  ];
  const colorFor = (cid) => cid < 0 ? '#454545' : PALETTE[cid % PALETTE.length];

  // Coordinates come back in [-50, 50]. Our viewBox is -120..120 × -80..80 so
  // we map points into a central pane leaving room for peripheral labels.
  const scaleX = 80 / 50;   // -80..80 horizontally
  const scaleY = 55 / 50;   // -55..55 vertically
  const px = (x) => x * scaleX;
  const py = (y) => y * scaleY;

  // Size scale — sqrt-normalised so cost differences read without one point dominating
  const maxCost = Math.max(...POINTS.map(p => p.cost_usd || 0), 0.001);
  const radiusFor = (cost) => 0.6 + 2.6 * Math.sqrt((cost || 0) / maxCost);

  // Render noise first (behind), then clusters (on top), labels topmost
  const byZ = POINTS.slice().sort((a, b) => (a.cluster_id < 0 ? -1 : 1) - (b.cluster_id < 0 ? -1 : 1));

  const NS = 'http://www.w3.org/2000/svg';
  let activeFilter = null;

  function applyFilter(cid) {
    activeFilter = cid;
    filter.style.display = cid == null ? 'none' : 'block';
    svg.querySelectorAll('circle').forEach(c => {
      const cc = parseInt(c.getAttribute('data-cluster'));
      const visible = cid == null || cc === cid;
      c.setAttribute('opacity', visible ? (cc < 0 ? 0.35 : 0.85) : 0.05);
    });
    svg.querySelectorAll('.cluster-label').forEach(g => {
      const cc = parseInt(g.getAttribute('data-cluster'));
      g.setAttribute('opacity', cid == null || cc === cid ? 1 : 0.15);
    });
  }
  filter.addEventListener('click', () => applyFilter(null));

  byZ.forEach(p => {
    const c = document.createElementNS(NS, 'circle');
    c.setAttribute('cx', px(p.x));
    c.setAttribute('cy', py(p.y));
    c.setAttribute('r', radiusFor(p.cost_usd));
    c.setAttribute('fill', colorFor(p.cluster_id));
    c.setAttribute('opacity', p.cluster_id < 0 ? 0.35 : 0.85);
    c.setAttribute('data-cluster', p.cluster_id);
    c.addEventListener('mouseover', (e) => {
      tip.innerHTML = `
        <div style="color:var(--green);font-weight:600;margin-bottom:4px;">${p.tool_name}${p.cluster_id >= 0 ? ` <span style="color:var(--fg-dim);font-weight:400;">· cluster ${p.cluster_id}</span>` : ' <span style="color:#888;font-weight:400;">· noise</span>'}</div>
        <div style="font-family:ui-monospace,monospace;color:var(--fg-dim);font-size:11px;word-break:break-all;">${(p.text || '').replace(/</g, '&lt;').slice(0, 240)}</div>
        <div style="color:var(--fg-dim);margin-top:6px;">$${(p.cost_usd || 0).toFixed(4)} · this turn</div>
      `;
      tip.style.opacity = '1';
    });
    c.addEventListener('mousemove', (e) => {
      const rect = root.getBoundingClientRect();
      let x = e.clientX - rect.left + 14;
      let y = e.clientY - rect.top + 14;
      if (x + 380 > rect.width) x = e.clientX - rect.left - 380;
      if (y + 120 > rect.height) y = e.clientY - rect.top - 120;
      tip.style.left = x + 'px';
      tip.style.top = y + 'px';
    });
    c.addEventListener('mouseout', () => { tip.style.opacity = '0'; });
    svg.appendChild(c);
  });

  // Helper: measure approx label width in viewBox units for pill background.
  const estLabelWidth = (s, fontSize) => s.length * fontSize * 0.58;

  // Greedy label placement: place each label slightly offset from its centroid
  // in the direction that has the most free space. Subsequent labels avoid
  // previously-placed ones by increasing the offset distance until clear.
  const placed = [];
  const padding = 1.2;
  function findLabelPosition(cx, cy, w, h) {
    // Try: offset straight up first; then variations outward + rotating
    const candidates = [
      [0, -h - 4],     // above
      [0, h + 4],      // below
      [w / 2 + 3, 0],  // right
      [-w / 2 - 3, 0], // left
      [w / 2 + 3, -h - 2],
      [-w / 2 - 3, -h - 2],
      [w / 2 + 3, h + 2],
      [-w / 2 - 3, h + 2],
    ];
    for (let scale = 1; scale <= 4; scale++) {
      for (const [dx, dy] of candidates) {
        const x = cx + dx * scale;
        const y = cy + dy * scale;
        // Viewport bounds check (leave a small margin)
        if (x - w / 2 < -118 || x + w / 2 > 118 || y - h / 2 < -78 || y + h / 2 > 78) continue;
        // Overlap check against already placed labels
        let collision = false;
        for (const p of placed) {
          if (Math.abs(x - p.x) < (w + p.w) / 2 + padding && Math.abs(y - p.y) < (h + p.h) / 2 + padding) {
            collision = true; break;
          }
        }
        if (!collision) return { x, y };
      }
    }
    // Last resort: push off-screen-bottom in a stacked column
    const fallbackY = 72 + placed.filter(p => p.fallback).length * (h + 2);
    return { x: cx, y: fallbackY, fallback: true };
  }

  // Cluster labels — only the top-N by spend were emitted server-side.
  // Draw a connector from the cluster centroid to the label pill to keep
  // the association visually explicit when labels are offset.
  LABELS.forEach(l => {
    const cx = px(l.x), cy = py(l.y);

    // Small halo at the true centroid
    const halo = document.createElementNS(NS, 'circle');
    halo.setAttribute('cx', cx);
    halo.setAttribute('cy', cy);
    halo.setAttribute('r', 2.4);
    halo.setAttribute('fill', 'none');
    halo.setAttribute('stroke', colorFor(l.cluster_id));
    halo.setAttribute('stroke-width', 0.55);
    halo.setAttribute('opacity', 0.9);
    svg.appendChild(halo);

    // Pill dimensions
    const fontSize = 2.8;
    const subSize = 1.9;
    const w = Math.max(estLabelWidth(l.label, fontSize), estLabelWidth(`${l.n_turns}× · ${l.confidence}`, subSize)) + 4;
    const h = fontSize + subSize + 3.5;

    const pos = findLabelPosition(cx, cy, w, h);
    placed.push({ x: pos.x, y: pos.y, w, h, fallback: !!pos.fallback });

    // Connector line (cluster centroid → pill edge)
    const line = document.createElementNS(NS, 'line');
    line.setAttribute('x1', cx);
    line.setAttribute('y1', cy);
    line.setAttribute('x2', pos.x);
    line.setAttribute('y2', pos.y);
    line.setAttribute('stroke', colorFor(l.cluster_id));
    line.setAttribute('stroke-width', 0.22);
    line.setAttribute('opacity', 0.45);
    svg.appendChild(line);

    // Pill background
    const g = document.createElementNS(NS, 'g');
    g.setAttribute('class', 'cluster-label');
    g.setAttribute('data-cluster', l.cluster_id);
    g.setAttribute('transform', `translate(${pos.x},${pos.y})`);
    g.style.cursor = 'pointer';
    const rect = document.createElementNS(NS, 'rect');
    rect.setAttribute('x', -w / 2);
    rect.setAttribute('y', -h / 2);
    rect.setAttribute('width', w);
    rect.setAttribute('height', h);
    rect.setAttribute('rx', 1.5);
    rect.setAttribute('fill', 'rgba(8,10,12,0.92)');
    rect.setAttribute('stroke', colorFor(l.cluster_id));
    rect.setAttribute('stroke-width', 0.35);
    g.appendChild(rect);

    // Primary label text — cluster pattern
    const t = document.createElementNS(NS, 'text');
    t.setAttribute('x', 0);
    t.setAttribute('y', -0.5);
    t.setAttribute('text-anchor', 'middle');
    t.setAttribute('fill', '#f4f7f5');
    t.setAttribute('font-size', fontSize);
    t.setAttribute('font-weight', '700');
    t.textContent = l.label;
    g.appendChild(t);

    // Secondary: n_turns · confidence
    const t2 = document.createElementNS(NS, 'text');
    t2.setAttribute('x', 0);
    t2.setAttribute('y', fontSize);
    t2.setAttribute('text-anchor', 'middle');
    t2.setAttribute('fill', colorFor(l.cluster_id));
    t2.setAttribute('font-size', subSize);
    t2.setAttribute('font-weight', '600');
    t2.textContent = `${l.n_turns}× · ${l.confidence}`;
    g.appendChild(t2);

    g.addEventListener('click', () => applyFilter(activeFilter === l.cluster_id ? null : l.cluster_id));
    svg.appendChild(g);
  });
})();
</script>
{% endif %}

<!-- EVIDENCE (diagnostic data, now framed as "why these rules hold") -->
