    <div class="kpi"><div class="k">Excluded</div><div class="v num" style="color:var(--fg-dim)">${{ r.spend_excluded_usd|money }}</div><div class="d">{{ r.n_noise }} noise turns, not in any dense cluster</div></div>
  </div>
